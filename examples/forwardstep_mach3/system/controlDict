FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     rhoCentralFoam;

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         10;                // 10 flow-through times (FT = L/U = 3/3 = 1)
                                   // First ~2 FT is transient, kept for safety;
                                   // last 8 FT is the snapshot window.

deltaT          5e-5;              // Conservative; adjustTimeStep will tighten it.

writeControl    adjustableRunTime;
writeInterval   0.02;              // ~500 snapshots over 10 FT; ~400 usable
                                   // after dropping the transient.

purgeWrite      0;                 // KEEP all snapshots: the GCI time series
                                   // and any later post-processing need the
                                   // full history. Do NOT use purgeWrite=10
                                   // (the tutorial default).

writeFormat     binary;            // CRITICAL: ASCII would 5–10x your disk
                                   // and slow the run noticeably.
writePrecision  8;
writeCompression off;              // Compressed binaries are slow to read in
                                   // Python.

timeFormat      general;
timePrecision   8;

runTimeModifiable true;

adjustTimeStep  no;
maxCo           0.2;               // Tutorial default; do not raise — central
                                   // schemes go unstable above ~0.5 on strong
                                   // shocks.
maxDeltaT       5e-5;

// ------------------------- function objects -------------------------------
functions
{
    // Cell-centered Mach number, useful for ParaView debugging.
    MachNo
    {
        type            MachNo;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        executeControl  writeTime;
    }

    // Schlieren-like |grad(rho)| for qualitative comparison against
    // Greenshields et al. (2010) Fig. 6 / Woodward-Colella Fig. 4.
    gradRho
    {
        type            grad;
        libs            ("libfieldFunctionObjects.so");
        field           rho;
        writeControl    writeTime;
        executeControl  writeTime;
    }

    // PRIMARY QoI source for foamgci: spatial extrema time series.
    // `location true` records (x y z) of each extremum — analyze.py
    // uses the peak-pressure location, so do not disable it.
    fieldMinMax
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        mode            magnitude;
        location        true;
        writeControl    timeStep;
        writeInterval   100;
        log             true;
        fields          (p rho);
    }
}

