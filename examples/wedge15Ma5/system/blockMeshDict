//   Extra-fine  (160 160 1)   (320 160 1)    76800     0.0009525
//   ----------------------------------------------------------------
// Edit the two (nx ny 1) tuples below per the table; change nothing else.

convertToMeters 1;

vertices
(
    (-0.15242 0       -0.005)
    ( 0       0       -0.005)
    ( 0.3048  0.081670913853  -0.005)
    (-0.15242 0.1524 -0.005)
    ( 0       0.1524 -0.005)
    ( 0.3048  0.1524 -0.005)

